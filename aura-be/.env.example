# Copy to .env and fill in real values. Never commit .env.
DEBUG=True
SECRET_KEY=change-me-generate-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.dev

# Postgres — local Homebrew instance on :5432
DATABASE_URL=postgres://aura:aura@localhost:5432/aura

ALLOWED_HOSTS=localhost,127.0.0.1

# Shared secret for AI-service <-> backend calls (must match aura-ai .env)
AI_SERVICE_TOKEN=shared-secret-change-me

# CORS origins (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,tauri://localhost
