# Copy to .env and fill in. Never commit .env.

# Where the Django backend (aura-be) lives.
BACKEND_URL=http://localhost:8000

# Shared service token — MUST match aura-be's AI_SERVICE_TOKEN.
AI_SERVICE_TOKEN=shared-secret-change-me

# JWT verification. Verify user tokens locally (fast, no round trip) using the
# SAME signing key as aura-be's Django SECRET_KEY. HS256 is simplejwt's default.
# Leave JWT_SECRET_KEY empty to instead validate via the backend's verify-service endpoint.
JWT_SECRET_KEY=dev-insecure-key-REPLACE-IN-PROD-0a1b2c3d4e5f6g7h8i9j
JWT_ALGORITHM=HS256

# STT model size: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base

# Google Gemini — conversational brain. Get a key from Google AI Studio.
# Leave GEMINI_API_KEY empty to fall back to the offline rule-based matcher.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_GROUNDING=True
USER_NAME=Sharad

# Optional: legacy/unused.
LLM_API_KEY=

# Server
HOST=0.0.0.0
PORT=8001
